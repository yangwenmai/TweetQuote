# 复制为 .env.local 后按需修改：cp .env.local.example .env.local
# 所有项均为可选，不配置也可运行（仅部分功能受限）

# ----- AI 翻译 / 智能注释（OpenAI 兼容） -----
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# ----- 推文链接自动抓取（TwitterAPI.io） -----
# TWITTERAPI_KEY=your-twitterapi-key
# 调试：在终端打出上游推文完整 JSON（已脱敏；需 NODE_ENV 非 production 且 debug 日志可见）
# TWITTER_LOG_FULL_TWEET_JSON=true

# ----- 管理接口鉴权（配额管理 Admin API） -----
# ADMIN_TOKEN=your-secret-admin-token

# ----- 可选：生产/代理场景下 API 对外地址 -----
# PUBLIC_API_BASE_URL=https://your-api.example.com

# ----- 本地 / 自建：托管抓取额度 -----
# 设为 true 时：不扣托管次数、永不 402（仍使用服务端 TWITTERAPI_KEY / AI 时生效）
# TWEETQUOTE_DISABLE_HOSTED_QUOTA=true
# 仅放宽默认上限（仍会扣次，除非同时关闭托管额度）：
# TWEETQUOTE_DAILY_TRIAL_LIMIT=100
# TWEETQUOTE_WEEKLY_TRIAL_LIMIT=1000
