{
  "name": "tweetquote-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @tweetquote/web",
    "dev:api": "npm run dev -w @tweetquote/api",
    "dev:extension": "npm run dev -w @tweetquote/extension",
    "start:api": "npm run start -w @tweetquote/api",
    "start:web": "npm run start -w @tweetquote/web",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:push": "npm run db:push -w @tweetquote/api"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.37",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
